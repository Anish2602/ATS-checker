# JWT Configuration
JWT_SECRET=supersecretjwtkeychangeinproduction1234567890!@#$
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration (Falls back to SQLite locally)
# DATABASE_URL=postgresql://user:password@localhost:5432/ats_checker

# OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
APPLE_CLIENT_ID=your-apple-client-id

# Email Delivery (Resend API)
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev

# Platform URLs (for link generation)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
